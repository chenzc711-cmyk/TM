.page { min-height: 100vh; background: linear-gradient(180deg, #fff 0%, #f7f8fb 48%, #fff 100%); overflow: hidden; }
.status-bar { height: 18rpx; }
.topbar { height: 76rpx; display: flex; align-items: center; justify-content: space-between; padding: 0 58rpx; color: #05070a; font-size: 30rpx; font-weight: 600; }
.capsule { width: 220rpx; height: 54rpx; border-radius: 40rpx; background: #000; }
.system-icons { font-size: 22rpx; letter-spacing: 5rpx; }
.title-row { height: 96rpx; padding: 0 30rpx 12rpx; display: grid; grid-template-columns: 170rpx 1fr 170rpx; align-items: center; }
.title { text-align: center; font-size: 34rpx; font-weight: 800; letter-spacing: 1rpx; }
.wechat-capsule { justify-self: end; width: 150rpx; height: 56rpx; border: 1rpx solid #e5e7eb; border-radius: 36rpx; display: flex; align-items: center; justify-content: space-around; color: #111827; background: rgba(255,255,255,.8); }
.divider { width: 1rpx; height: 32rpx; background: #d9dde5; }
.nav-shell { position: relative; background: rgba(255,255,255,.92); border-bottom: 1rpx solid #e6e8ee; }
.nav-scroll { white-space: nowrap; width: 100%; }
.nav-list { display: inline-flex; min-width: 100%; align-items: center; padding: 0 28rpx; height: 84rpx; }
.nav-item { position: relative; padding: 0 20rpx; height: 84rpx; line-height: 84rpx; font-size: 27rpx; color: #1f2937; flex: 0 0 auto; }
.nav-item.active { color: #ff1028; font-weight: 800; }
.nav-item.active::after { content: ''; position: absolute; left: 18rpx; right: 18rpx; bottom: 0; height: 8rpx; border-radius: 8rpx 8rpx 0 0; background: #ff1028; }
.menu-trigger { font-size: 34rpx; color: #5c6473; }
.menu-pop { position: absolute; z-index: 20; right: 20rpx; top: 78rpx; width: 260rpx; background: #fff; border-radius: 24rpx; box-shadow: 0 16rpx 50rpx rgba(25,33,50,.16); padding: 12rpx; }
.menu-item { padding: 22rpx; border-bottom: 1rpx solid #f0f1f4; }
.content { height: calc(100vh - 274rpx); }
.hero { margin: 28rpx; min-height: 260rpx; border-radius: 28rpx; padding: 38rpx 28rpx; position: relative; overflow: hidden; display: flex; justify-content: space-between; background: linear-gradient(135deg, #ff1431 0%, #f20b26 48%, #ff315b 100%); box-shadow: 0 18rpx 36rpx rgba(255,16,40,.24); color: #fff; }
.hero::before { content: ''; position: absolute; right: 150rpx; top: 40rpx; width: 190rpx; height: 140rpx; opacity: .22; background-image: radial-gradient(#fff 2rpx, transparent 2rpx); background-size: 18rpx 18rpx; }
.hero-copy { position: relative; z-index: 2; max-width: 470rpx; }
.hero-en { font-size: 25rpx; opacity: .95; margin-bottom: 8rpx; }
.hero-title { font-size: 52rpx; line-height: 1.1; font-weight: 900; margin-bottom: 22rpx; }
.hero-desc { font-size: 26rpx; line-height: 1.5; margin-bottom: 30rpx; }
.hero-btn { width: 152rpx; height: 58rpx; line-height: 58rpx; text-align: center; border-radius: 36rpx; background: #fff; color: #ff1028; font-weight: 800; font-size: 24rpx; }
.hero-art { position: absolute; right: 34rpx; bottom: 34rpx; width: 230rpx; height: 170rpx; }
.box { position: absolute; border-radius: 10rpx; transform: skewY(-8deg); background: linear-gradient(145deg, rgba(255,255,255,.98), rgba(255,201,207,.78)); box-shadow: 0 18rpx 36rpx rgba(128,0,15,.25); }
.box-a { width: 92rpx; height: 88rpx; right: 86rpx; top: 12rpx; }
.box-b { width: 78rpx; height: 70rpx; right: 16rpx; top: 48rpx; opacity: .82; }
.shelf { position: absolute; right: 0; bottom: 0; width: 218rpx; height: 82rpx; border-radius: 18rpx; background: linear-gradient(145deg, #ffedef, #ff9aa8); box-shadow: inset 0 -12rpx 0 rgba(255,16,40,.36); }
.panel { padding: 0 28rpx 26rpx; }
.period-card, .form-card, .list-card, .product-card, .record-card, .return-card, .channel-balance-card { background: rgba(255,255,255,.94); border-radius: 24rpx; box-shadow: 0 12rpx 36rpx rgba(31,41,55,.07); border: 1rpx solid rgba(228,231,237,.7); }
.period-card { display: flex; align-items: center; gap: 14rpx; padding: 16rpx; margin: 0 0 30rpx; overflow-x: auto; }
.period { min-width: 118rpx; height: 52rpx; line-height: 52rpx; border-radius: 32rpx; text-align: center; color: #6b7280; background: #fafafa; }
.period.on { color: #ff1028; background: #fff0f2; font-weight: 800; }
.date-btn { min-width: 180rpx; height: 52rpx; line-height: 50rpx; border-radius: 30rpx; border: 1rpx solid #e5e7eb; text-align: center; color: #606876; background: #fff; }
.section-title { display: flex; align-items: center; gap: 14rpx; font-size: 32rpx; font-weight: 900; margin: 26rpx 0 20rpx; }
.section-title text { width: 7rpx; height: 30rpx; background: #ff1028; border-radius: 8rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; }
.link { color: #8b919d; }
.card-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18rpx; }
.metric-card { min-height: 194rpx; padding: 24rpx 16rpx; text-align: center; background: #fff; border-radius: 20rpx; box-shadow: 0 10rpx 28rpx rgba(31,41,55,.07); }
.metric-icon, .no-image-icon { margin: 0 auto 14rpx; width: 60rpx; height: 60rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; color: #ff1028; background: #ffe8ec; }
.metric-icon.orange, .metric-icon.orangeSolid { color: #fb7c0d; background: #fff0df; }
.metric-icon.yellow { color: #f2b500; background: #fff7d6; }
.metric-icon.redSolid { color: #fff; background: linear-gradient(135deg, #ff5470, #ff1028); }
.metric-icon.orangeSolid { color: #fff; background: linear-gradient(135deg, #ffc171, #ff9a28); }
.metric-label { color: #111827; font-size: 22rpx; }
.metric-value { font-size: 30rpx; font-weight: 900; margin: 12rpx 0; }
.metric-trend { display: flex; justify-content: center; gap: 12rpx; font-size: 21rpx; color: #8b919d; }
.up, .assist-delta text { color: #ff1028; font-weight: 700; }
.assist-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18rpx; }
.assist-card { min-height: 118rpx; padding: 24rpx; display: flex; align-items: center; gap: 22rpx; background: #fff; border-radius: 20rpx; box-shadow: 0 10rpx 28rpx rgba(31,41,55,.06); }
.assist-card .metric-icon { margin: 0; }
.assist-label, .muted { color: #6b7280; font-size: 23rpx; line-height: 1.55; }
.assist-value { font-size: 30rpx; font-weight: 900; }
.channel-row, .channel-balance-card, .inbound-row { min-height: 102rpx; padding: 20rpx 22rpx; display: flex; align-items: center; gap: 22rpx; border-bottom: 1rpx solid #f0f1f4; }
.channel-row:last-child, .inbound-row:last-child { border-bottom: 0; }
.row-main { flex: 1; min-width: 0; }
.row-title { font-size: 29rpx; font-weight: 900; color: #172033; line-height: 1.35; }
.money { color: #f20b26; font-size: 31rpx; font-weight: 900; white-space: nowrap; }
.chev { color: #969ca8; font-size: 44rpx; }
.page-heading { font-size: 42rpx; font-weight: 900; margin: 8rpx 0 24rpx; }
.form-card { padding: 24rpx; margin-bottom: 26rpx; }
.grid-form { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22rpx; }
.field label, .line-field label { display: block; margin-bottom: 12rpx; font-size: 25rpx; font-weight: 700; color: #20283a; }
.field input, .field textarea, .picker-input, .line-field input, .picker-text { width: 100%; min-height: 58rpx; padding: 0 20rpx; border: 1rpx solid #e0e3e9; border-radius: 12rpx; background: #fff; color: #1f2937; font-size: 24rpx; }
.field textarea { height: 108rpx; padding-top: 18rpx; }
.primary-btn, .ghost-btn { height: 62rpx; line-height: 62rpx; border-radius: 12rpx; text-align: center; font-weight: 900; font-size: 27rpx; }
.primary-btn { color: #fff; background: linear-gradient(90deg, #ff1028, #f20b26); }
.ghost-btn { color: #364152; background: #f3f5f8; }
.full { width: 100%; }
.span-2 { grid-column: span 2; }
.product-card { display: flex; gap: 22rpx; margin-bottom: 18rpx; padding: 24rpx; }
.no-thumb-card { /* intentionally no thumbnail images; records use text-only content or CSS badges */ }
.mini-stats { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 18rpx; white-space: pre-line; color: #1f2937; text-align: center; gap: 18rpx; }
.product-side { width: 210rpx; text-align: right; }
.small-btn { display: inline-block; width: 76rpx; height: 48rpx; line-height: 48rpx; margin: 34rpx 0 0 12rpx; border-radius: 10rpx; color: #374151; background: #f1f3f7; font-size: 23rpx; }
.small-btn.danger { color: #f20b26; background: #ffe7e9; }
.line-form { display: flex; flex-direction: column; gap: 16rpx; }
.line-field { display: grid; grid-template-columns: 130rpx 1fr 46rpx; align-items: center; gap: 14rpx; }
.line-field label { margin: 0; }
.line-field text { color: #6b7280; text-align: center; }
.record-card { margin-bottom: 14rpx; }
.compact { position: relative; min-height: 128rpx; padding: 22rpx 160rpx 22rpx 24rpx; }
.qty { position: absolute; right: 28rpx; top: 24rpx; text-align: right; font-size: 30rpx; font-weight: 900; }
.qty text { display: block; color: #6b7280; font-size: 22rpx; font-weight: 400; }
.operator { position: absolute; right: 28rpx; bottom: 22rpx; }
.tri { min-width: 330rpx; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18rpx; text-align: center; white-space: pre-line; font-weight: 800; }
.tri text { color: #1f2937; }
.return-card { position: relative; margin-bottom: 18rpx; padding: 22rpx; }
.status { position: absolute; top: 18rpx; right: 20rpx; padding: 6rpx 18rpx; color: #f20b26; background: #ffe7eb; border-radius: 28rpx; font-size: 22rpx; }
.return-cols { display: grid; grid-template-columns: 1fr 1.15fr; gap: 26rpx; margin-top: 18rpx; }
.channel-form { padding: 34rpx 28rpx; display: flex; flex-direction: column; gap: 26rpx; }
.channel-balance-card { margin-bottom: 18rpx; border-bottom: 0; }
.channel-balance-card .no-image-icon { margin: 0; flex: 0 0 auto; }
.footer { color: #9aa0aa; text-align: center; font-size: 22rpx; padding: 22rpx 0 44rpx; }
@media (max-width: 380px) { .card-grid { grid-template-columns: repeat(2, 1fr); } .assist-grid, .grid-form { grid-template-columns: 1fr; } .span-2 { grid-column: span 1; } }
