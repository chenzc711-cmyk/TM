page {
  min-height: 100%;
  background: #f8f9fb;
  color: #192132;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
}
view, text, input, button, picker, textarea {
  box-sizing: border-box;
}
button {
  margin: 0;
  padding: 0;
  line-height: normal;
  border: 0;
  background: transparent;
}
button::after { border: 0; }
